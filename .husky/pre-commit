# Pre-commit léger : format + lint des fichiers stagés uniquement (rapide).

# Fix Windows : GitHub Desktop bash ne trouve pas Node sans cet ajout au PATH.
if [ -d "/c/Program Files/nodejs" ]; then
  export PATH="/c/Program Files/nodejs:$PATH"
fi

# Sur Windows, utilise npx.cmd si le bash-npx est absent
if command -v npx >/dev/null 2>&1; then
  npx lint-staged
elif [ -f "/c/Program Files/nodejs/npx.cmd" ]; then
  "/c/Program Files/nodejs/npx.cmd" lint-staged
else
  echo "ERROR: npx not found. Install Node.js or fix PATH."
  exit 1
fi