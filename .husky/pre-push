# Pre-push : garde-fou complet (typecheck + tests) avant d'envoyer du code.
# Même contournement Windows/GHD que pre-commit : on évite npm/npx (bash absent),
# on appelle tsc et vitest directement depuis node_modules/.bin.

if ! command -v node >/dev/null 2>&1 && [ -d "/c/Program Files/nodejs" ]; then
  export PATH="/c/Program Files/nodejs:$PATH"
fi

if ! command -v node >/dev/null 2>&1; then
  echo "ERROR: node introuvable. Installe Node.js ou corrige le PATH." >&2
  exit 1
fi

tsc --noEmit && vitest run
