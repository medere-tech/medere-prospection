!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# Firebase service account credentials (JAMAIS COMMIT — clés privées admin SDK)
firebase-service-account.json
firebase-service-account*.json
*-firebase-adminsdk-*.json

# tmp/ — golden test reports + scratch local (rapports JSON contiennent
