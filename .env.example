# =============================================================================
# Médéré Prospection IA — Variables d'environnement (TEMPLATE)
# -----------------------------------------------------------------------------
# Copier ce fichier en `.env.local` (gitignoré) et remplir les valeurs.
# RÈGLE ABSOLUE : aucun secret en `NEXT_PUBLIC_*` (inliné dans le bundle client
# et lisible par tous). Seules les clés réellement publiques le sont (Clerk
# publishable, Sentry DSN public).
# La validation stricte au boot vit dans src/lib/security/env.ts (Zod).
# =============================================================================

# === Application ===
# Environnement d'exécution. Doit valoir development | production | test.
NODE_ENV=development
# URL publique de l'app (liens absolus, CORS, callbacks/webhooks).
# Dev : http://localhost:3000 — Prod : https://<domaine-vercel>.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret applicatif générique (signatures internes, etc.).
# Générer : openssl rand -base64 32
APP_SECRET=

# === Anthropic Claude ===
# Clé API pour la génération/classification SMS (Claude Sonnet 4.6).
# Obtenir : https://console.anthropic.com/ (Settings > API Keys)
# Scope : clé de projet dédiée Médéré, jamais partagée.
ANTHROPIC_API_KEY=

# === OVHcloud SMS ===
# API OVH pour l'envoi/réception SMS. Souverain FR.
# Obtenir une app : https://api.ovh.com/createApp/
OVH_ENDPOINT=ovh-eu
OVH_APP_KEY=
OVH_APP_SECRET=
# consumerKey scopé sur POST /sms/*/jobs UNIQUEMENT (moindre privilège).
# À générer via le script scripts/ovh-create-credentials.ts (écrit en Phase 1).
OVH_CONSUMER_KEY=
# Nom du service SMS OVH (ex: sms-ab12345-1). Espace client OVH > SMS.
OVH_SMS_SERVICE_NAME=
# Expéditeur affiché (Sender ID), max 11 caractères alphanumériques.
OVH_SMS_SENDER=Medere
# Secret partagé pour signer/vérifier le webhook SMS entrant (HMAC).
# Valeur libre forte : openssl rand -hex 32
OVH_WEBHOOK_SECRET=

# === Twilio (Lookup v2 uniquement) ===
# Validation des numéros (type de ligne, carrier, validité).
# Obtenir : https://console.twilio.com/ (Account Info)
# Scope : compte limité au Lookup, pas d'envoi.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === HubSpot (CRM) ===
# Token d'une Private App HubSpot.
# Obtenir : HubSpot > Settings > Integrations > Private Apps
# Scopes minimaux : crm.objects.contacts.read/write, crm.objects.deals.read/write
HUBSPOT_ACCESS_TOKEN=
# Identifiant du portail HubSpot (Settings > Account & Billing).
HUBSPOT_PORTAL_ID=

# === Lusha (enrichissement) ===
# Clé API v2 (header `api_key`) pour enrichir téléphone/email.
# Obtenir : https://dashboard.lusha.com/ (API)
LUSHA_API_KEY=

# === Slack (notifications hand-off) ===
# Bot token (xoxb-...). Obtenir : https://api.slack.com/apps > OAuth & Permissions
# Scopes minimaux : chat:write, users:read, channels:read
SLACK_BOT_TOKEN=
# Signing secret pour vérifier la signature HMAC des webhooks Slack entrants.
# Basic Information > App Credentials > Signing Secret.
SLACK_SIGNING_SECRET=
# ID du canal de notification des leads chauds (#leads-chauds).
# Clic droit sur le canal > Copier le lien > l'ID est en fin d'URL (C...).
SLACK_HANDOFF_CHANNEL_ID=
# Mapping spécialité -> Slack user ID (JSON). Ex : {"dentaire":"U05...","medecin":"U08..."}
SLACK_USER_IDS=

# === Firebase Admin (Firestore côté serveur) ===
# Identifiants du service account (clé privée JSON).
# Obtenir : console Firebase > Paramètres du projet > Comptes de service >
# Générer une nouvelle clé privée.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Clé privée PEM. Conserver les \n échappés sur UNE ligne entre guillemets.
# Ex : FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# === Firestore Emulator (dev/test uniquement) ===
# Active la connexion Admin SDK vers l'emulator local au lieu de la prod.
# Format : host:port. Doit matcher firebase.json (port 8085).
# NE JAMAIS définir cette variable en prod — bypass total des credentials.
# Décommenter en dev local et en CI.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8085
#
# Override du cache des binaires firebase-tools (download du JAR emulator).
# OBLIGATOIRE sur Windows si le home contient un caractère non-ASCII
# (ex: "Déthié" → Java râle sur certains chemins UTF-8 dans le PATH).
# Path ASCII pur recommandé : C:/firebase-cache (créé par scripts/setup-firebase-cache.mjs).
# Si absent + home ASCII → Firebase utilise son défaut ~/.cache/firebase.
# FIREBASE_CACHE_DIR=C:/firebase-cache

# === Inngest (jobs background) ===
# Clés event + signing. Obtenir : https://app.inngest.com/ > Manage > Keys
INNGEST_EVENT_KEY=
# Signing key pour vérifier la signature des requêtes Inngest entrantes.
INNGEST_SIGNING_KEY=

# === Sentry (observabilité) ===
# DSN serveur. Obtenir : https://sentry.io/ > Project Settings > Client Keys (DSN)
# Important : projet en région EU (RGPD).
SENTRY_DSN=
# DSN exposé au client (public par nature). Souvent identique au DSN ci-dessus.
NEXT_PUBLIC_SENTRY_DSN=

# === Upstash Redis (rate limiting) ===
# REST URL + token. Obtenir : https://console.upstash.com/ > base Redis > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Auth dashboard (Clerk) ===
# Clé publishable (PUBLIQUE, OK en NEXT_PUBLIC_). Obtenir : https://dashboard.clerk.com/
# > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clé secrète Clerk (côté serveur uniquement, JAMAIS NEXT_PUBLIC_).
CLERK_SECRET_KEY=
