{
  "name": "medere-prospection",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:firestore": "node scripts/setup-firebase-cache.mjs && firebase emulators:exec --only firestore --project medere-test \"vitest run --config vitest.config.firestore.ts\"",
    "test:firestore:coverage": "node scripts/setup-firebase-cache.mjs && firebase emulators:exec --only firestore --project medere-test \"vitest run --config vitest.config.firestore.ts --coverage\"",
    "test:firestore-rules": "node scripts/setup-firebase-cache.mjs && firebase emulators:exec --only firestore --project medere-rules-test \"vitest run --config vitest.config.firestore-rules.ts\"",
    "test:all": "npm test && npm run test:firestore && npm run test:firestore-rules",
    "test:e2e": "playwright test",
    "emulator:firestore": "node scripts/setup-firebase-cache.mjs && firebase emulators:start --only firestore --project medere-test",
    "emulator:check": "node scripts/setup-firebase-cache.mjs",
    "emulator:kill": "node scripts/kill-emulator-port.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.4.1",
    "@hookform/resolvers": "^5.4.0",
    "@hubspot/api-client": "^13.5.0",
    "@ovhcloud/node-ovh": "^3.0.0",
    "@sentry/nextjs": "^10.54.0",
    "@slack/web-api": "^7.16.0",
    "@slack/webhook": "^7.0.9",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "firebase-admin": "^13.10.0",
    "inngest": "^4.4.0",
    "libphonenumber-js": "^1.13.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "firebase-tools": "^14.21.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
